pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo "Cloning repository..."
                git branch: 'main', 
                    url: 'https://github.com/your-username/your-repo.git'
            }
        }

        stage('Verify') {
            steps {
                echo "Listing files..."
                sh 'ls -la'
            }
        }

        stage('Test') {
            steps {
                echo "Pipeline test successful!"
            }
        }
    }
}