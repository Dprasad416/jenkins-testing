pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo "Cloning from Git..."
                checkout scm
            }
        }

        stage('Build') {
            steps {
                echo "Building project..."
                sh 'mvn clean install'
            }
        }

        stage('Test') {
            steps {
                echo "Running tests..."
                sh 'mvn test'
            }
        }

        stage('Deploy') {
            steps {
                echo "Deployment step (demo only)"
            }
        }
    }

    post {
        success {
            echo "Pipeline executed successfully!"
        }
        failure {
            echo "Pipeline failed!"
        }
    }
}